<!-- ===== BLOG SECTION ===== -->

<section class="section">
  <div class="container">

```
<h2 class="section-title">Latest Stories</h2>

<% if (blogs && blogs.length > 0) { %>
  <div class="blog-grid">

    <% blogs.forEach(blog => { %>
      <div class="blog-card">

        <!-- Image -->
        <% if (blog.image) { %>
          <div class="card-image" style="background-image: url('/uploads/<%= blog.image %>')"></div>
        <% } else { %>
          <div class="card-image card-image-placeholder"></div>
        <% } %>

        <!-- Content -->
       <div class="card-body">

  <!-- Tags -->
  <div class="card-tags">
    <% if (blog.tags) { %>
      <% blog.tags.forEach(tag => { %>
        <span class="tag"><%= tag.trim() %></span>
      <% }) %>
    <% } %>
  </div>

  <!-- Title -->
  <h3 class="card-title">
    <a href="/blog/<%= blog._id %>">
      <%= blog.title %>
    </a>
  </h3>

  <!-- Excerpt -->
  <p class="card-excerpt">
    <%= blog.excerpt || blog.content.substring(0, 100) + "..." %>
  </p>

  <!-- Meta -->
  <div class="card-meta">
    <span>📅 <%= new Date(blog.createdAt).toDateString() %></span>
  </div>

  <!-- 🔥 ACTION BUTTONS -->
  <% if (user && blog.user && blog.user.toString() === user._id.toString()) { %>

    <div class="card-actions">

      <!-- Edit -->
      <a href="/admin/edit-blog/<%= blog._id %>" class="btn-edit">
        ✏️ Edit
      </a>

      <!-- Delete -->
      <form action="/admin/delete-blog/<%= blog._id %>" method="POST" style="display:inline;">
        <button type="submit" class="btn-delete" onclick="return confirm('Delete this blog?')">
          🗑️ Delete
        </button>
      </form>

    </div>

  <% } %>

</div>
      </div>
    <% }) %>

  </div>
<% } else { %>

  <!-- Empty state -->
  <div class="empty-state">
    <p>No blogs yet 😢</p>

    <% if (user) { %>
      <a href="/blog/add" class="btn-primary">Write First Blog</a>
    <% } %>
  </div>

<% } %>
```

  </div>
</section>


