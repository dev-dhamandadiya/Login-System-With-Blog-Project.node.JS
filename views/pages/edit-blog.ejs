<%- include('../partials/header.ejs') %>

<div class="container py-5">
  <div class="col-md-8 mx-auto">

    <h2 class="mb-4">Edit Blog</h2>

    <form action="/blog/updateBlog/<%= blog._id %>" method="POST" enctype="multipart/form-data" class="card p-4 shadow-sm">

      <div class="mb-3">
        <label class="form-label">Title</label>
        <input type="text" name="title" value="<%= blog.title %>" class="form-control">
      </div>

      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea name="description" rows="5" class="form-control"><%= blog.description %></textarea>
      </div>

      <div class="mb-3">
        <label class="form-label">Change Image</label>
        <input type="file" name="image" class="form-control">
      </div>

      <% if (blog.image) { %>
        <img src="/uploads/<%= blog.image %>" class="img-fluid rounded mb-3" style="max-height:200px;">
      <% } %>

      <button class="btn btn-success w-100">Update</button>

    </form>

  </div>
</div>

<%- include('../partials/footer.ejs') %>